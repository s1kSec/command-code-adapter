CC_ADAPTER_CC_API_KEY=["user_your_key_here","user_another_key"]  # JSON array of CC API keys
CC_ADAPTER_CC_BASE_URL=https://api.commandcode.ai
CC_ADAPTER_HOST=0.0.0.0
CC_ADAPTER_PORT=8080
CC_ADAPTER_LOG_LEVEL=INFO
CC_ADAPTER_LOG_FORMAT=console    # "console" or "json"
CC_ADAPTER_ADMIN_PASSWORD=    # Admin panel password, empty = no login required
CC_ADAPTER_ACCESS_KEY=sk-your-key  # Access key for /v1/chat/completions, empty = no auth
CC_ADAPTER_DEFAULT_MODEL=deepseek/deepseek-v4-flash  # Default model for playground and verify
CC_ADAPTER_WEB_SEARCH_PROVIDER=  # Set to "deepseek" to forward Anthropic web_search to DeepSeek
CC_ADAPTER_DEEPSEEK_API_KEY=  # DeepSeek API key used when web_search forwarding is enabled
CC_ADAPTER_DEEPSEEK_ANTHROPIC_URL=https://api.deepseek.com/anthropic
CC_ADAPTER_WEB_SEARCH_MODEL=  # Optional DeepSeek model override for web_search forwarding; empty = request model
